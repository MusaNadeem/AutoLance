*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
backend/.venv/
backend/venv/
.venv/
venv/

# Celery
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid
backend/celerybeat/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
