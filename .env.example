# ─────────────────────────────────────────────────────────────────────────────
# AutoLance — Environment Variables
# Copy this file to .env and fill in the values.
# Required variables must be set before the app will start.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver for async SQLAlchemy)
# Docker Compose: postgresql+asyncpg://freelanceradar:secret@postgres:5432/freelanceradar
# Local dev:      postgresql+asyncpg://freelanceradar:secret@127.0.0.1:5433/freelanceradar
DATABASE_URL=postgresql+asyncpg://freelanceradar:secret@postgres:5432/freelanceradar

# Redis connection string — used by Celery broker and result backend
REDIS_URL=redis://redis:6379/0

# Anthropic API key — required for cover letter generation (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# JWT signing secret — any long random string, keep it private
SECRET_KEY=change-me-to-a-long-random-string

# JWT access token secret (can be the same as SECRET_KEY or separate)
JWT_SECRET=change-me-to-another-long-random-string

# Directory where uploaded CV files are stored
# Inside Docker: /app/uploads   Local dev: /tmp/autolance_uploads
UPLOAD_DIR=/app/uploads

# ── Optional — Bright Data scraping proxy ────────────────────────────────────

# Bright Data API key for residential proxy scraping of Upwork
# Leave blank to run without scraping (useful for development)
BRIGHT_DATA_API_KEY=

# ── Optional — Slack notifications ───────────────────────────────────────────

# Slack incoming webhook URL for high-match job alerts
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=

# ── Optional — Email notifications ───────────────────────────────────────────

# SMTP settings for email alert dispatch
# Leave all blank to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@autolance.app

# ── Optional — Score weights ─────────────────────────────────────────────────
# These control how the 4 signals combine into the overall match score.
# Must all be floats that sum to 1.0.
# Defaults shown below — only set if you want to override them.

# Weight for job-to-profile skill relevance (default: 0.40)
SCORE_WEIGHT_RELEVANCE=0.40

# Weight for client quality signal (hire rate × avg rating × jobs posted) (default: 0.25)
SCORE_WEIGHT_CLIENT_QUALITY=0.25

# Weight for budget fit signal (how well the budget matches your target rates) (default: 0.20)
SCORE_WEIGHT_BUDGET=0.20

# Weight for competition level signal (lower proposals count = higher score) (default: 0.15)
SCORE_WEIGHT_COMPETITION=0.15

# ── Optional — Scraping schedule ─────────────────────────────────────────────

# How often to run the scraper (in minutes). Default: 20
SCRAPE_INTERVAL_MINUTES=20

# ── Frontend ─────────────────────────────────────────────────────────────────
# Set this in frontend/.env.local or as a Docker build arg

# Base URL of the FastAPI backend — no trailing slash
NEXT_PUBLIC_API_URL=http://localhost:8000
